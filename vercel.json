              {authMode === "login" ? "Sign in to sync your progress across all devices." : authMode === "signup" ? "Start your journey to Grade 9 today." : "We'll send a reset link to your email."}
            </p>

            {authMode === "signup" && (
              <div style={{ marginBottom: 14 }}>
                <label style={S.label}>Your first name</label>
                <input style={S.input} placeholder="e.g. Amara" value={authName} onChange={e => setAuthName(e.target.value)} />
              </div>
            )}

            <div style={{ marginBottom: 14 }}>
              <label style={S.label}>Email address</label>
              <input style={S.input} type="email" placeholder="you@example.com" value={authEmail} onChange={e => setAuthEmail(e.target.value)} />
            </div>

            {authMode !== "forgot" && (
              <div style={{ marginBottom: 20 }}>
                <label style={S.label}>Password</label>
                <input style={S.input} type="password" placeholder={authMode === "signup" ? "Min. 6 characters" : "Your password"} value={authPassword} onChange={e => setAuthPassword(e.target.value)}
                  onKeyDown={e => e.key === "Enter" && handleAuth()} />
              </div>
            )}

            {authError && (
              <div style={{ background: dark ? "#450a0a" : "#fef2f2", border: `1px solid ${dark ? "#dc262644" : "#fca5a5"}`, borderRadius: 10, padding: "10px 14px", fontSize: 13, color: dark ? "#f87171" : "#dc2626", marginBottom: 16 }}>
                {authError}
              </div>
            )}

            <button style={{ ...S.btn, width: "100%", opacity: authLoading ? 0.7 : 1 }} onClick={handleAuth} disabled={authLoading}>
              {authLoading ? "Please wait..." : authMode === "login" ? "Sign In" : authMode === "signup" ? "Create Account" : "Send Reset Link"}
            </button>

            <div style={{ marginTop: 16, textAlign: "center", fontSize: 13 }}>
              {authMode === "login" && (
                <>
                  <span style={{ color: t.muted }}>Don't have an account? </span>
                  <button style={{ background: "none", border: "none", color: t.accent, fontWeight: 700, cursor: "pointer", fontSize: 13 }} onClick={() => { setAuthMode("signup"); setAuthError(""); }}>Sign up free</button>
                  <div style={{ marginTop: 8 }}>
                    <button style={{ background: "none", border: "none", color: t.muted, cursor: "pointer", fontSize: 12 }} onClick={() => { setAuthMode("forgot"); setAuthError(""); }}>Forgot password?</button>
                  </div>
                </>
              )}
              {authMode === "signup" && (
                <>
                  <span style={{ color: t.muted }}>Already have an account? </span>
                  <button style={{ background: "none", border: "none", color: t.accent, fontWeight: 700, cursor: "pointer", fontSize: 13 }} onClick={() => { setAuthMode("login"); setAuthError(""); }}>Sign in</button>
                </>
              )}
              {authMode === "forgot" && (
                <button style={{ background: "none", border: "none", color: t.accent, fontWeight: 700, cursor: "pointer", fontSize: 13 }} onClick={() => { setAuthMode("login"); setAuthError(""); }}>← Back to sign in</button>
              )}
            </div>

            {/* Guest mode */}
            <div style={{ marginTop: 20, paddingTop: 16, borderTop: `1px solid ${t.border}`, textAlign: "center" }}>
              <button style={{ ...S.btnGhost, fontSize: 12, padding: "8px 16px" }}
                onClick={() => {
                  const saved = localStorage.getItem("apex_data");
                  if (saved) { const d = JSON.parse(saved); if (d.profile) { setProfile(d.profile); setSubjects(d.subjects||[]); setTopics(d.topics||{}); setSessions(d.sessions||[]); setStreak(d.streak||0); setAnswerHistory(d.answerHistory||[]); setScreen("dashboard"); return; } }
                  setScreen("onboarding");
                }}>
                Continue without account (local only)
              </button>
              <p style={{ ...S.muted, fontSize: 11, margin: "8px 0 0" }}>Data won't sync across devices</p>
            </div>
          </div>

          <div style={{ textAlign: "center", marginTop: 20, ...S.muted, fontSize: 11 }}>
            Your data is encrypted and stored securely via Supabase.
          </div>
        </div>
      </div>
    );
  }


  if (screen === "onboarding") {
    return (
      <div style={S.app}>
        <div style={{ maxWidth: 560, margin: "0 auto", padding: "40px 20px" }}>
          {/* Logo */}
          <div style={{ textAlign: "center", marginBottom: 48 }}>
            <div style={{ fontSize: 48, marginBottom: 8 }}>🏔️</div>
            <div style={{ fontSize: 32, fontWeight: 800, letterSpacing: -1, color: t.text }}>Apex</div>
            <div style={{ color: t.muted, fontSize: 14, marginTop: 4 }}>The Road to Grade 9</div>
          </div>

          {/* Step indicators */}
          <div style={{ display: "flex", gap: 8, justifyContent: "center", marginBottom: 40 }}>
            {["You", "Subjects", "Ready"].map((s, i) => (
              <div key={i} style={{ display: "flex", alignItems: "center", gap: 8 }}>
                <div style={{ width: 28, height: 28, borderRadius: "50%", background: i <= onboardStep ? t.accent : t.card2, border: `1px solid ${i <= onboardStep ? t.accent : t.border}`, display: "flex", alignItems: "center", justifyContent: "center", fontSize: 12, fontWeight: 700, color: i <= onboardStep ? "#fff" : t.muted }}>
                  {i < onboardStep ? "✓" : i + 1}
                </div>
                <span style={{ fontSize: 12, color: i <= onboardStep ? t.text : t.muted, fontWeight: i === onboardStep ? 700 : 400 }}>{s}</span>
                {i < 2 && <div style={{ width: 32, height: 1, background: t.border }} />}
              </div>
            ))}
          </div>

          {onboardStep === 0 && (
            <div style={S.card}>
              <h2 style={{ margin: "0 0 8px", fontSize: 22, fontWeight: 800 }}>Welcome! Let's get you set up 👋</h2>
              <p style={{ ...S.muted, margin: "0 0 28px" }}>Tell us a bit about yourself so Apex can personalise your revision journey.</p>
              <label style={S.label}>Your first name</label>
              <input style={S.input} placeholder="e.g. Amara" value={onboardName} onChange={e => setOnboardName(e.target.value)} />
              <button style={{ ...S.btn, width: "100%", marginTop: 24, opacity: onboardName.trim() ? 1 : 0.5 }} onClick={() => onboardName.trim() && setOnboardStep(1)}>
                Continue →
              </button>
            </div>
          )}

          {onboardStep === 1 && (
            <div style={S.card}>
              <h2 style={{ margin: "0 0 4px", fontSize: 22, fontWeight: 800 }}>Your GCSE Subjects</h2>
              <p style={{ ...S.muted, margin: "0 0 24px" }}>Add each subject you're taking. You can always add more later.</p>

              {/* Add subject form */}
              <div style={{ ...S.card2, marginBottom: 20 }}>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginBottom: 12 }}>
                  <div>
                    <label style={S.label}>Subject</label>
                    <select style={S.select} value={onboardForm.name} onChange={e => setOnboardForm(p => ({ ...p, name: e.target.value }))}>
                      {SUBJECTS_LIST.map(s => <option key={s}>{s}</option>)}
                    </select>
                  </div>
                  <div>
                    <label style={S.label}>Exam Board</label>
                    <select style={S.select} value={onboardForm.board} onChange={e => setOnboardForm(p => ({ ...p, board: e.target.value }))}>
                      {EXAM_BOARDS.map(b => <option key={b}>{b}</option>)}
                    </select>
                  </div>
                  <div>
                    <label style={S.label}>Current Grade</label>
                    <select style={S.select} value={onboardForm.currentGrade} onChange={e => setOnboardForm(p => ({ ...p, currentGrade: e.target.value }))}>
                      {GRADES.map(g => <option key={g}>{g}</option>)}
                    </select>
                  </div>
                  <div>
                    <label style={S.label}>Target Grade</label>
                    <select style={S.select} value={onboardForm.targetGrade} onChange={e => setOnboardForm(p => ({ ...p, targetGrade: e.target.value }))}>
                      {GRADES.map(g => <option key={g}>{g}</option>)}
                    </select>
                  </div>
                </div>
                <div style={{ marginBottom: 12 }}>
                  <label style={S.label}>Exam Date</label>
                  <input type="date" style={S.input} value={onboardForm.examDate} onChange={e => setOnboardForm(p => ({ ...p, examDate: e.target.value }))} />
                </div>
                <button style={{ ...S.btn, width: "100%", fontSize: 13, padding: "10px 16px" }}
                  onClick={() => {
                    if (onboardSubjects.find(s => s.name === onboardForm.name)) { notify("Already added!"); return; }
                    setOnboardSubjects(prev => [...prev, { ...onboardForm, id: Date.now() }]);
                    notify(`${onboardForm.name} added ✓`);
                  }}>
                  + Add Subject
                </button>
              </div>

              {/* Added subjects */}
              {onboardSubjects.map(sub => (
                <div key={sub.id} style={{ ...S.card2, marginBottom: 8, display: "flex", alignItems: "center", justifyContent: "space-between" }}>
                  <div>
                    <div style={{ fontWeight: 700, fontSize: 14 }}>{sub.name}</div>
                    <div style={{ ...S.muted, fontSize: 12 }}>{sub.board} · Grade {sub.currentGrade} → {sub.targetGrade} · {sub.examDate || "No date set"}</div>
                  </div>
                  <button style={{ ...S.btnGhost, padding: "6px 12px", fontSize: 12 }} onClick={() => setOnboardSubjects(p => p.filter(s => s.id !== sub.id))}>✕</button>
                </div>
              ))}

              {onboardSubjects.length > 0 && (
                <button style={{ ...S.btn, width: "100%", marginTop: 16 }} onClick={() => setOnboardStep(2)}>
                  Continue ({onboardSubjects.length} subject{onboardSubjects.length > 1 ? "s" : ""}) →
                </button>
              )}
              {onboardSubjects.length === 0 && <p style={{ ...S.muted, textAlign: "center", marginTop: 8 }}>Add at least one subject to continue</p>}
            </div>
          )}

          {onboardStep === 2 && (
            <div style={S.card}>
              <div style={{ textAlign: "center", marginBottom: 28 }}>
                <div style={{ fontSize: 52, marginBottom: 12 }}>🚀</div>
                <h2 style={{ margin: "0 0 8px", fontSize: 24, fontWeight: 800 }}>You're all set, {onboardName}!</h2>
                <p style={{ ...S.muted, margin: 0 }}>Your personalised revision plan is ready. The 2357 method will guide you to Grade 9.</p>
              </div>
              <div style={{ ...S.card2, marginBottom: 20 }}>
                <div style={{ fontWeight: 700, marginBottom: 12, fontSize: 13, textTransform: "uppercase", letterSpacing: 0.8, color: t.muted }}>Your Subjects</div>
                {onboardSubjects.map(sub => (
                  <div key={sub.id} style={{ display: "flex", justifyContent: "space-between", padding: "8px 0", borderBottom: `1px solid ${t.border}` }}>
                    <div style={{ fontWeight: 600, fontSize: 14 }}>{sub.name}</div>
                    <div style={{ ...S.muted, fontSize: 12 }}>{sub.board} · {sub.currentGrade}→{sub.targetGrade}</div>
                  </div>
                ))}
              </div>
              <button style={{ ...S.btn, width: "100%" }} onClick={completeOnboarding}>
                Start Revising 🏔️
              </button>
            </div>
          )}
        </div>
      </div>
    );
  }

  // ── Quiz Screen ──────────────────────────────────────────────────────────────
  if (screen === "quiz" && quizState) {
    const q = quizState.question;
    return (
      <div style={{ ...S.app, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", minHeight: "100vh", padding: 20 }}>
        <div style={{ maxWidth: 600, width: "100%" }}>
          {/* Header */}
          <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 32 }}>
            <button style={S.btnGhost} onClick={() => setScreen("dashboard")}>← Back</button>
            <div style={{ textAlign: "center" }}>
              <div style={{ fontWeight: 800, fontSize: 16 }}>🏔️ Apex</div>
              <div style={{ ...S.muted, fontSize: 12 }}>{quizState.subject} · {q.topic}</div>
            </div>
            <div style={{ background: t.accentSoft, border: `1px solid ${t.accent}44`, borderRadius: 8, padding: "4px 12px", fontSize: 13, color: t.accent, fontWeight: 600 }}>
              Grade {q.grade}
            </div>
          </div>

          {/* Question card */}
          <div style={{ ...S.card, marginBottom: 20, textAlign: "center" }}>
            <div style={{ fontSize: 11, fontWeight: 700, textTransform: "uppercase", letterSpacing: 1, color: t.muted, marginBottom: 16 }}>{q.subtopic}</div>
            <p style={{ fontSize: 20, fontWeight: 700, lineHeight: 1.5, margin: "0 0 24px" }}>{q.question}</p>

            {/* Student answer input */}
            <textarea
              style={{ ...S.input, minHeight: 100, resize: "vertical", marginBottom: 16, fontSize: 15, border: quizState.revealed ? `1px solid ${t.border}` : `1px solid ${t.border}` }}
              placeholder="Write your answer here before revealing..."
              value={quizState.answer}
              onChange={e => !quizState.revealed && setQuizState(p => ({ ...p, answer: e.target.value }))}
              readOnly={quizState.revealed}
            />

            {/* Reveal / Comparison */}
            {!quizState.revealed ? (
              <button style={{ ...S.btn, width: "100%" }} onClick={() => setQuizState(p => ({ ...p, revealed: true }))}>
                Reveal Answer
              </button>
            ) : (
              <>
                {/* Side-by-side comparison */}
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 12, marginBottom: 16, textAlign: "left" }}>
                  <div style={{ background: dark ? "#1a1000" : "#fefce8", border: `1px solid ${dark ? "#92400e44" : "#fbbf2444"}`, borderRadius: 12, padding: 14 }}>
                    <div style={{ fontSize: 10, fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.8, color: dark ? "#fbbf24" : "#d97706", marginBottom: 6 }}>📝 Your Answer</div>
                    <div style={{ fontSize: 13, lineHeight: 1.5, color: t.text }}>{quizState.answer || <span style={{ color: t.muted, fontStyle: "italic" }}>No answer written</span>}</div>
                  </div>
                  <div style={{ background: dark ? "#0d1a0d" : "#f0fdf4", border: `1px solid ${dark ? "#16653144" : "#bbf7d044"}`, borderRadius: 12, padding: 14 }}>
                    <div style={{ fontSize: 10, fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.8, color: dark ? "#4ade80" : "#16a34a", marginBottom: 6 }}>✅ Correct Answer</div>
                    <div style={{ fontSize: 13, lineHeight: 1.5, color: t.text }}>{q.answer}</div>
                  </div>
                </div>
                {q.hint && <div style={{ ...S.muted, fontSize: 13, marginBottom: 16, fontStyle: "italic", textAlign: "left" }}>💡 {q.hint}</div>}
              </>
            )}
          </div>

          {/* Confidence + self-mark */}
          {quizState.revealed && (
            <>
              <div style={{ ...S.card, marginBottom: 16 }}>
                <div style={{ fontWeight: 700, marginBottom: 12, fontSize: 14 }}>How confident were you? <span style={{ color: t.muted, fontWeight: 400, fontSize: 12 }}>(before you looked)</span></div>
                <div style={{ display: "flex", gap: 8, justifyContent: "center", marginBottom: 8 }}>
                  {[1, 2, 3, 4, 5].map(n => (
                    <button key={n} style={{
                      width: 48, height: 48, borderRadius: 10, border: `2px solid ${quizState.confidence === n ? t.accent : t.border}`,
                      background: quizState.confidence === n ? t.accentSoft : t.card2, color: quizState.confidence === n ? t.accent : t.muted,
                      fontWeight: 800, fontSize: 16, cursor: "pointer",
                    }} onClick={() => setQuizState(p => ({ ...p, confidence: n }))}>
                      {n}
                    </button>
                  ))}
                </div>
                <div style={{ display: "flex", justifyContent: "space-between" }}>
                  <span style={{ ...S.muted, fontSize: 11 }}>Not sure</span>
                  <span style={{ ...S.muted, fontSize: 11 }}>Very sure</span>
                </div>
              </div>

              {/* Clear correct/incorrect buttons */}
              <div style={{ ...S.card, marginBottom: 16 }}>
                <div style={{ fontWeight: 700, marginBottom: 12, fontSize: 14 }}>Did you get it right?</div>
                <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
                  <button
                    style={{ background: dark ? "#14532d" : "#dcfce7", border: `2px solid ${dark ? "#16a34a" : "#86efac"}`, borderRadius: 12, padding: "14px", cursor: "pointer", color: dark ? "#4ade80" : "#15803d", fontWeight: 800, fontSize: 15 }}
                    onClick={() => submitQuiz(true)}>
                    ✓ Yes, I got it
                  </button>
                  <button
                    style={{ background: dark ? "#450a0a" : "#fef2f2", border: `2px solid ${dark ? "#dc2626" : "#fca5a5"}`, borderRadius: 12, padding: "14px", cursor: "pointer", color: dark ? "#f87171" : "#dc2626", fontWeight: 800, fontSize: 15 }}
                    onClick={() => submitQuiz(false)}>
                    ✗ No, I didn't
                  </button>
                </div>
              </div>
            </>
          )}
        </div>
      </div>
    );
  }

  // ── Results Screen ────────────────────────────────────────────────────────────
  if (screen === "results" && quizResult) {
    const isDanger = quizResult.label === "Danger Zone";
    const isMastered = quizResult.label === "Mastered";
    const resultColor = isMastered ? (dark ? "#4ade80" : "#16a34a") : isDanger ? (dark ? "#f87171" : "#dc2626") : t.accent;
    const messages = {
      "Mastered": `Brilliant! You nailed ${quizResult.topic} and you knew it. The 2357 engine is pushing this further out — see you in a few days!`,
      "Lucky": `Correct, but you weren't sure. No worries — we'll revisit ${quizResult.topic} again soon to make it stick properly.`,
      "Danger Zone": `You were confident but that one caught you out! That's actually great — your brain will remember this now. ${isDanger ? "The AI Tutor below can explain it." : ""}`,
      "Learning Gap": `Not to worry — ${quizResult.topic} has been reset in your schedule. Review your notes, then come back to it.`,
    };

    return (
      <div style={{ ...S.app, display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", minHeight: "100vh", padding: 20 }}>
        <div style={{ maxWidth: 560, width: "100%" }}>
          <div style={{ ...S.card, textAlign: "center", marginBottom: 16 }}>
            <div style={{ fontSize: 48, marginBottom: 12 }}>
              {isMastered ? "🎉" : isDanger ? "⚠️" : quizResult.correct ? "✅" : "📚"}
            </div>
            <div style={{ fontSize: 20, fontWeight: 800, color: resultColor, marginBottom: 8 }}>{quizResult.label}</div>
            <p style={{ ...S.muted, margin: "0 0 20px", lineHeight: 1.6 }}>{messages[quizResult.label]}</p>

            {/* Mastery bar */}
            <div style={{ background: t.card2, borderRadius: 8, height: 8, marginBottom: 8 }}>
              <div style={{ height: "100%", borderRadius: 8, background: resultColor, width: `${quizResult.mastery}%`, transition: "width 0.8s ease" }} />
            </div>
            <div style={{ ...S.muted, fontSize: 12, marginBottom: 20 }}>Topic mastery: {quizResult.mastery}%</div>

            {isDanger && (
              <div style={{ marginBottom: 20 }}>
                {!aiExplanation ? (
                  <button style={{ ...S.btn, background: dark ? "#7c3aed" : "#6d28d9", width: "100%" }} onClick={getAiExplanation} disabled={aiLoading}>
                    {aiLoading ? "Loading AI Tutor..." : "✨ Explain it to me (AI Tutor)"}
                  </button>
                ) : (
                  <div style={{ background: dark ? "#1e1533" : "#f5f3ff", border: `1px solid ${dark ? "#7c3aed44" : "#7c3aed22"}`, borderRadius: 12, padding: 16, textAlign: "left" }}>
                    <div style={{ fontSize: 12, fontWeight: 700, color: dark ? "#a78bfa" : "#7c3aed", marginBottom: 8, textTransform: "uppercase", letterSpacing: 0.8 }}>✨ AI Tutor</div>
                    <p style={{ margin: 0, fontSize: 14, lineHeight: 1.6, color: t.text }}>{aiExplanation}</p>
                  </div>
                )}
              </div>
            )}

            <div style={{ display: "flex", gap: 12 }}>
              <button style={{ ...S.btn, flex: 1 }} onClick={() => { setScreen("quiz"); startQuiz(quizState?.subject || subjects[0]?.name); }}>
                Next Question
              </button>
              <button style={S.btnGhost} onClick={() => setScreen("dashboard")}>Dashboard</button>
            </div>
          </div>
        </div>
      </div>
    );
  }

  // ── Review Screen ─────────────────────────────────────────────────────────────
  if (screen === "review") {
    const resultColors = {
      "Mastered": dark ? "#4ade80" : "#16a34a",
      "Lucky": dark ? "#fbbf24" : "#d97706",
      "Danger Zone": dark ? "#f87171" : "#dc2626",
      "Learning Gap": dark ? "#60a5fa" : "#2563eb",
    };
    const resultIcons = { "Mastered": "🎉", "Lucky": "🤞", "Danger Zone": "⚠️", "Learning Gap": "📚" };
    const filtered = reviewFilter === "all" ? answerHistory : answerHistory.filter(h => {
      if (reviewFilter === "danger") return h.result === "Danger Zone";
      if (reviewFilter === "mastered") return h.result === "Mastered";
      if (reviewFilter === "lucky") return h.result === "Lucky";
      if (reviewFilter === "gap") return h.result === "Learning Gap";
      return true;
    });

    return (
      <div style={S.app}>
        {/* Nav */}
        <div style={S.nav}>
          <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
            <button style={{ ...S.btnGhost, padding: "6px 14px", fontSize: 13 }} onClick={() => setScreen("dashboard")}>← Dashboard</button>
          </div>
          <div style={{ fontWeight: 800, fontSize: 16 }}>🏔️ Answer Review</div>
          <div style={{ ...S.muted, fontSize: 12 }}>{answerHistory.length} answers recorded</div>
        </div>

        <div style={{ maxWidth: 800, margin: "0 auto", padding: "24px 20px" }}>
          <div style={{ marginBottom: 20 }}>
            <h1 style={{ margin: "0 0 4px", fontSize: 22, fontWeight: 800 }}>Your Answer History</h1>
            <p style={{ ...S.muted, margin: 0, fontSize: 13 }}>Review every question you've answered, compare your response to the correct answer, and spot patterns.</p>
          </div>

          {/* Summary stats */}
          {answerHistory.length > 0 && (
            <div style={{ display: "grid", gridTemplateColumns: "repeat(4, 1fr)", gap: 12, marginBottom: 20 }}>
              {[
                { label: "Total Answered", value: answerHistory.length, color: t.accent },
                { label: "Mastered", value: answerHistory.filter(h => h.result === "Mastered").length, color: dark ? "#4ade80" : "#16a34a" },
                { label: "Danger Zone", value: answerHistory.filter(h => h.result === "Danger Zone").length, color: dark ? "#f87171" : "#dc2626" },
                { label: "Accuracy", value: `${Math.round((answerHistory.filter(h => h.correct).length / answerHistory.length) * 100)}%`, color: dark ? "#60a5fa" : "#2563eb" },
              ].map(stat => (
                <div key={stat.label} style={{ ...S.card, textAlign: "center", padding: 16 }}>
                  <div style={{ fontSize: 22, fontWeight: 800, color: stat.color, marginBottom: 2 }}>{stat.value}</div>
                  <div style={{ ...S.muted, fontSize: 11, textTransform: "uppercase", letterSpacing: 0.6 }}>{stat.label}</div>
                </div>
              ))}
            </div>
          )}

          {/* Filter tabs */}
          <div style={{ display: "flex", gap: 8, marginBottom: 20, flexWrap: "wrap" }}>
            {[
              { key: "all", label: "All" },
              { key: "danger", label: "⚠️ Danger Zone" },
              { key: "mastered", label: "🎉 Mastered" },
              { key: "lucky", label: "🤞 Lucky" },
              { key: "gap", label: "📚 Learning Gap" },
            ].map(f => (
              <button key={f.key}
                style={{ background: reviewFilter === f.key ? t.accent : t.card2, color: reviewFilter === f.key ? "#fff" : t.muted, border: `1px solid ${reviewFilter === f.key ? t.accent : t.border}`, borderRadius: 8, padding: "7px 14px", fontSize: 12, fontWeight: 600, cursor: "pointer" }}
                onClick={() => setReviewFilter(f.key)}>
                {f.label}
              </button>
            ))}
          </div>

          {/* Answer cards */}
          {filtered.length === 0 ? (
            <div style={{ ...S.card, textAlign: "center", padding: 40 }}>
              <div style={{ fontSize: 36, marginBottom: 12 }}>📭</div>
              <div style={{ fontWeight: 700, marginBottom: 8 }}>No answers yet</div>
              <p style={{ ...S.muted, margin: 0, fontSize: 13 }}>Complete some quizzes and your answers will appear here for review.</p>
              <button style={{ ...S.btn, marginTop: 16 }} onClick={() => setScreen("dashboard")}>Start a Quiz</button>
            </div>
          ) : (
            <div style={{ display: "flex", flexDirection: "column", gap: 14 }}>
              {filtered.map(entry => {
                const col = resultColors[entry.result] || t.muted;
                const timeAgo = (() => {
                  const diff = Date.now() - new Date(entry.timestamp);
                  const mins = Math.floor(diff / 60000);
                  const hours = Math.floor(diff / 3600000);
                  const days = Math.floor(diff / 86400000);
                  if (mins < 1) return "just now";
                  if (mins < 60) return `${mins}m ago`;
                  if (hours < 24) return `${hours}h ago`;
                  return `${days}d ago`;
                })();

                return (
                  <div key={entry.id} style={{ ...S.card, borderLeft: `4px solid ${col}` }}>
                    {/* Header row */}
                    <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center", marginBottom: 14, flexWrap: "wrap", gap: 8 }}>
                      <div style={{ display: "flex", gap: 8, alignItems: "center", flexWrap: "wrap" }}>
                        <span style={{ background: `${col}18`, color: col, borderRadius: 6, padding: "3px 10px", fontSize: 12, fontWeight: 700 }}>
                          {resultIcons[entry.result]} {entry.result}
                        </span>
                        <span style={{ background: t.card2, color: t.muted, borderRadius: 6, padding: "3px 10px", fontSize: 11, fontWeight: 600 }}>{entry.subject}</span>
                        <span style={{ background: t.card2, color: t.muted, borderRadius: 6, padding: "3px 10px", fontSize: 11, fontWeight: 600 }}>{entry.subtopic}</span>
                        <span style={{ background: t.accentSoft, color: t.accent, borderRadius: 6, padding: "3px 10px", fontSize: 11, fontWeight: 700 }}>Grade {entry.grade}</span>
                      </div>
                      <div style={{ display: "flex", gap: 10, alignItems: "center" }}>
                        <span style={{ ...S.muted, fontSize: 11 }}>Confidence: {entry.confidence}/5</span>
                        <span style={{ ...S.muted, fontSize: 11 }}>{timeAgo}</span>
                      </div>
                    </div>

                    {/* Question */}
                    <div style={{ fontWeight: 700, fontSize: 14, marginBottom: 12, lineHeight: 1.4 }}>Q: {entry.question}</div>

                    {/* Answer comparison */}
                    <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 10 }}>
                      <div style={{ background: entry.correct ? (dark ? "#0d1a0d" : "#f0fdf4") : (dark ? "#1a0000" : "#fff5f5"), border: `1px solid ${entry.correct ? (dark ? "#16653144" : "#bbf7d044") : (dark ? "#dc262644" : "#fca5a544")}`, borderRadius: 10, padding: 12 }}>
                        <div style={{ fontSize: 10, fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.8, color: entry.correct ? (dark ? "#4ade80" : "#16a34a") : (dark ? "#f87171" : "#dc2626"), marginBottom: 6 }}>
                          {entry.correct ? "✓ Your Answer (Correct)" : "✗ Your Answer (Incorrect)"}
                        </div>
                        <div style={{ fontSize: 12, lineHeight: 1.5, color: t.text }}>{entry.studentAnswer || <span style={{ fontStyle: "italic", color: t.muted }}>No answer written</span>}</div>
                      </div>
                      <div style={{ background: dark ? "#0d1a0d" : "#f0fdf4", border: `1px solid ${dark ? "#16653144" : "#bbf7d044"}`, borderRadius: 10, padding: 12 }}>
                        <div style={{ fontSize: 10, fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.8, color: dark ? "#4ade80" : "#16a34a", marginBottom: 6 }}>✅ Correct Answer</div>
                        <div style={{ fontSize: 12, lineHeight: 1.5, color: t.text }}>{entry.correctAnswer}</div>
                      </div>
                    </div>

                    {/* Mastery bar */}
                    <div style={{ marginTop: 12, display: "flex", alignItems: "center", gap: 10 }}>
                      <div style={{ ...S.muted, fontSize: 11, whiteSpace: "nowrap" }}>Topic mastery:</div>
                      <div style={{ flex: 1, background: t.card2, borderRadius: 4, height: 4 }}>
                        <div style={{ height: "100%", borderRadius: 4, background: col, width: `${entry.mastery}%`, transition: "width 0.6s" }} />
                      </div>
                      <div style={{ fontSize: 11, fontWeight: 700, color: col, whiteSpace: "nowrap" }}>{entry.mastery}%</div>
                    </div>
                  </div>
                );
              })}
            </div>
          )}
        </div>
      </div>
    );
  }


  const dueToday = getTodaysDue();
  const todayTip = TIPS[new Date().getDay() % TIPS.length];
  const nextExam = subjects.filter(s => s.examDate).sort((a, b) => new Date(a.examDate) - new Date(b.examDate))[0];

  return (
    <div style={S.app}>
      {/* Notification */}
      {notification && (
        <div style={{ position: "fixed", top: 20, left: "50%", transform: "translateX(-50%)", background: t.accent, color: "#fff", padding: "10px 24px", borderRadius: 50, fontWeight: 600, fontSize: 14, zIndex: 999, boxShadow: "0 4px 24px #0006" }}>
          {notification}
        </div>
      )}

      {/* Nav */}
      <div style={S.nav}>
        <div style={{ display: "flex", alignItems: "center", gap: 10 }}>
          <span style={{ fontSize: 20 }}>🏔️</span>
          <div>
            <div style={{ fontWeight: 800, fontSize: 17, letterSpacing: -0.5 }}>Apex</div>
            <div style={{ fontSize: 11, color: t.muted }}>The Road to Grade 9</div>
          </div>
        </div>
        <div style={{ display: "flex", alignItems: "center", gap: 12 }}>
          {streak > 0 && (
            <div style={{ background: t.accentSoft, border: `1px solid ${t.accent}44`, borderRadius: 8, padding: "4px 10px", fontSize: 13, color: t.accent, fontWeight: 700 }}>
              🔥 {streak}
            </div>
          )}
          <button onClick={() => setScreen("review")} style={{ ...S.btnGhost, padding: "8px 14px", fontSize: 13 }}>
            📖 Review
          </button>
          <button onClick={() => setDark(d => !d)} style={{ ...S.btnGhost, padding: "8px 14px", fontSize: 13 }}>
            {dark ? "☀️ Light" : "🌙 Dark"}
          </button>
          <div style={{ position: "relative" }}>
            <div
              style={{ width: 34, height: 34, borderRadius: "50%", background: t.accent, display: "flex", alignItems: "center", justifyContent: "center", fontWeight: 800, fontSize: 14, color: "#fff", cursor: "pointer" }}
              title="Sign out"
              onClick={async () => {
                if (window.confirm("Sign out of Apex?")) {
                  await sbSignOut();
                  setProfile(null); setSubjects([]); setTopics({}); setSessions([]); setStreak(0); setAnswerHistory([]);
                  localStorage.removeItem("apex_data");
                  setScreen("auth");
                }
              }}>
              {profile?.name?.[0]?.toUpperCase()}
            </div>
          </div>
        </div>
      </div>

      <div style={{ maxWidth: 900, margin: "0 auto", padding: "24px 20px" }}>
        {/* Greeting */}
        <div style={{ marginBottom: 24 }}>
          <h1 style={{ margin: "0 0 4px", fontSize: 26, fontWeight: 800, letterSpacing: -0.5 }}>
            Good {new Date().getHours() < 12 ? "morning" : new Date().getHours() < 17 ? "afternoon" : "evening"}, {profile?.name} 👋
          </h1>
          <p style={{ ...S.muted, margin: 0 }}>
            {dueToday.length > 0 ? `You have ${dueToday.length} topic${dueToday.length > 1 ? "s" : ""} due for review today.` : "You're all caught up! Great work."}
          </p>
        </div>

        {/* Top row */}
        <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 16, marginBottom: 16 }}>
          {/* Start Session hero */}
          <div style={{ ...S.card, background: dark ? "#1a1000" : "#fffbeb", border: `1px solid ${t.accent}44`, gridColumn: "1 / -1" }}>
            <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", flexWrap: "wrap", gap: 16 }}>
              <div style={{ flex: 1 }}>
                <div style={{ fontSize: 11, fontWeight: 700, textTransform: "uppercase", letterSpacing: 1, color: t.accent, marginBottom: 6 }}>Your Next Session</div>
                {dueToday.length > 0 ? (
                  <>
                    <div style={{ fontSize: 20, fontWeight: 800, marginBottom: 4 }}>
                      {dueToday[0].subtopic} · <span style={{ color: t.muted, fontWeight: 500, fontSize: 16 }}>{dueToday[0].subject}</span>
                    </div>
                    <div style={{ ...S.muted, fontSize: 13 }}>
                      {dueToday.length} session{dueToday.length > 1 ? "s" : ""} queued today · 🔥 {streak} day streak
                    </div>
                  </>
                ) : (
                  <div style={{ fontSize: 18, fontWeight: 700 }}>All caught up for today! 🎉</div>
                )}
              </div>
              {dueToday.length > 0 && (
                <button style={{ ...S.btn, fontSize: 16, padding: "14px 32px", borderRadius: 50 }}
                  onClick={() => startQuiz(dueToday[0].subject)}>
                  ▶ Start Session
                </button>
              )}
            </div>

            {/* Today's schedule dropdown (simple list) */}
            {dueToday.length > 1 && (
              <div style={{ marginTop: 16, paddingTop: 16, borderTop: `1px solid ${t.border}` }}>
                <div style={{ fontSize: 12, fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.8, color: t.muted, marginBottom: 10 }}>Today's Queue</div>
                <div style={{ display: "flex", flexWrap: "wrap", gap: 8 }}>
                  {dueToday.slice(0, 6).map((item, i) => (
                    <div key={i} style={{ background: t.card2, border: `1px solid ${t.border}`, borderRadius: 8, padding: "6px 12px", fontSize: 12, fontWeight: 600 }}>
                      {item.subtopic} <span style={{ color: t.muted, fontWeight: 400 }}>· {item.subject}</span>
                    </div>
                  ))}
                  {dueToday.length > 6 && <div style={{ ...S.muted, fontSize: 12, padding: "6px 0", alignSelf: "center" }}>+{dueToday.length - 6} more</div>}
                </div>
              </div>
            )}
          </div>
        </div>

        {/* Exam countdown + daily tip */}
        <div style={{ display: "grid", gridTemplateColumns: nextExam ? "1fr 1fr" : "1fr", gap: 16, marginBottom: 24 }}>
          {nextExam && (
            <div style={{ ...S.card, display: "flex", alignItems: "center", gap: 16 }}>
              <div style={{ fontSize: 36 }}>📅</div>
              <div>
                <div style={{ fontSize: 12, fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.8, color: t.muted, marginBottom: 4 }}>Next Exam</div>
                <div style={{ fontWeight: 800, fontSize: 17 }}>{nextExam.name}</div>
                <div style={{ color: t.accent, fontWeight: 700, fontSize: 15 }}>
                  {daysUntil(nextExam.examDate) !== null ? `${daysUntil(nextExam.examDate)} days away` : "Date not set"}
                </div>
              </div>
            </div>
          )}
          <div style={{ ...S.card, background: dark ? "#0d1a0d" : "#f0fdf4", border: `1px solid ${dark ? "#166534" : "#bbf7d0"}` }}>
            <div style={{ fontSize: 11, fontWeight: 700, textTransform: "uppercase", letterSpacing: 0.8, color: dark ? "#4ade80" : "#16a34a", marginBottom: 6 }}>💡 Daily Tip</div>
            <p style={{ margin: 0, fontSize: 13, lineHeight: 1.6, color: t.text }}>{todayTip}</p>
          </div>
        </div>

        {/* Subject cards */}
        <div style={{ marginBottom: 8, display: "flex", justifyContent: "space-between", alignItems: "center" }}>
          <div style={{ fontWeight: 800, fontSize: 17 }}>Your Subjects</div>
          <div style={{ ...S.muted, fontSize: 12 }}>{subjects.length} subject{subjects.length !== 1 ? "s" : ""}</div>
        </div>

        <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fill, minmax(260px, 1fr))", gap: 16, marginBottom: 32 }}>
          {subjects.map(sub => {
            const mastery = getSubjectMastery(sub.name);
            const col = masteryColor(mastery, dark);
            const due = dueToday.filter(d => d.subject === sub.name).length;
            const bank = QUIZ_BANK[sub.name] || [];
            const subTopics = topics[sub.name] || [];
            const mastered = subTopics.filter(t => t.mastery >= 80).length;
            const days = daysUntil(sub.examDate);

            return (
              <div key={sub.id} style={{ ...S.card, cursor: "pointer", transition: "transform 0.2s, box-shadow 0.2s" }}
                onMouseEnter={e => { e.currentTarget.style.transform = "translateY(-2px)"; e.currentTarget.style.boxShadow = `0 8px 32px #0004`; }}
                onMouseLeave={e => { e.currentTarget.style.transform = "translateY(0)"; e.currentTarget.style.boxShadow = "none"; }}
                onClick={() => startQuiz(sub.name)}>
                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "flex-start", marginBottom: 16 }}>
                  <div>
                    <div style={{ fontWeight: 800, fontSize: 16, marginBottom: 2 }}>{sub.name}</div>
                    <div style={{ ...S.muted, fontSize: 12 }}>{sub.board} · Target: Grade {sub.targetGrade}</div>
                  </div>
                  {/* Circular mastery ring */}
                  <svg width={56} height={56} viewBox="0 0 56 56">
                    <circle cx={28} cy={28} r={22} fill="none" stroke={dark ? "#1f2d45" : "#e5ddd0"} strokeWidth={5} />
                    <circle cx={28} cy={28} r={22} fill="none" stroke={col} strokeWidth={5}
                      strokeDasharray={`${2 * Math.PI * 22 * mastery / 100} ${2 * Math.PI * 22}`}
                      strokeLinecap="round" transform="rotate(-90 28 28)" style={{ transition: "stroke-dasharray 0.8s ease" }} />
                    <text x={28} y={33} textAnchor="middle" fontSize={11} fontWeight={800} fill={col}>{mastery}%</text>
                  </svg>
                </div>

                {/* Progress bar */}
                <div style={{ background: t.card2, borderRadius: 6, height: 6, marginBottom: 10, overflow: "hidden" }}>
                  <div style={{ height: "100%", borderRadius: 6, background: col, width: `${mastery}%`, transition: "width 0.6s ease" }} />
                </div>

                <div style={{ display: "flex", justifyContent: "space-between", alignItems: "center" }}>
                  <div style={{ fontSize: 12, color: t.muted }}>
                    {mastered}/{bank.length} mastered
                  </div>
                  <div style={{ display: "flex", gap: 8 }}>
                    {due > 0 && (
                      <span style={{ background: "#dc262618", color: dark ? "#f87171" : "#dc2626", borderRadius: 6, padding: "2px 8px", fontSize: 11, fontWeight: 700 }}>
                        {due} due
                      </span>
                    )}
                    {days !== null && days >= 0 && (
                      <span style={{ background: t.accentSoft, color: t.accent, borderRadius: 6, padding: "2px 8px", fontSize: 11, fontWeight: 700 }}>
                        {days}d
                      </span>
                    )}
                  </div>
                </div>

                <div style={{ marginTop: 12, display: "flex", gap: 8 }}>
                  <div style={{ flex: 1, background: t.card2, borderRadius: 8, padding: "8px 10px", textAlign: "center" }}>
                    <div style={{ fontSize: 15, fontWeight: 800, color: col }}>{masteryLabel(mastery)}</div>
                    <div style={{ fontSize: 10, color: t.muted, marginTop: 1 }}>Status</div>
                  </div>
                  <div style={{ flex: 1, background: t.card2, borderRadius: 8, padding: "8px 10px", textAlign: "center" }}>
                    <div style={{ fontSize: 15, fontWeight: 800 }}>Grade {sub.currentGrade}→{sub.targetGrade}</div>
                    <div style={{ fontSize: 10, color: t.muted, marginTop: 1 }}>Progress</div>
                  </div>
                </div>
              </div>
            );
          })}

          {/* Add subject card */}
          <div style={{ ...S.card, border: `2px dashed ${t.border}`, cursor: "pointer", display: "flex", flexDirection: "column", alignItems: "center", justifyContent: "center", minHeight: 180, opacity: 0.7 }}
            onClick={() => {
              const name = prompt("Subject name (or pick):", SUBJECTS_LIST[0]);
              if (!name) return;
              const board = prompt("Exam board:", "AQA") || "AQA";
              const examDate = prompt("Exam date (YYYY-MM-DD):", "") || "";
              const currentGrade = prompt("Current grade (U-9):", "5") || "5";
              const targetGrade = prompt("Target grade (U-9):", "8") || "8";
              const newSub = { id: Date.now(), name, board, examDate, currentGrade, targetGrade };
              const newSubjects = [...subjects, newSub];
              const bank = QUIZ_BANK[name] || [];
              const newTopics = { ...topics, [name]: bank.map(q => ({ id: q.id, topic: q.topic, subtopic: q.subtopic, mastery: 0, stage: 0, streak: 0, correct: 0, total: 0, nextReview: new Date().toISOString().split("T")[0] })) };
              setSubjects(newSubjects); setTopics(newTopics);
              save(profile, newSubjects, newTopics, sessions, streak);
              notify(`${name} added!`);
            }}>
            <div style={{ fontSize: 28, marginBottom: 8 }}>+</div>
            <div style={{ fontWeight: 600, fontSize: 14, color: t.muted }}>Add Subject</div>
          </div>
        </div>

        {/* 2357 explainer */}
        <div style={{ ...S.card, background: dark ? "#080f1a" : "#f8f6f0", marginBottom: 24 }}>
          <div style={{ fontWeight: 800, fontSize: 15, marginBottom: 12 }}>📐 Your 2357 Spaced Repetition Schedule</div>
          <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
            {["Learn it", "Day 2", "Day 3", "Day 5", "Day 7", "Mastered!"].map((label, i) => (
              <div key={i} style={{ display: "flex", alignItems: "center", gap: 6 }}>
                <div style={{ background: i === 0 ? t.accent : i === 5 ? (dark ? "#4ade80" : "#16a34a") : t.card2, border: `1px solid ${t.border}`, borderRadius: 8, padding: "6px 12px", fontSize: 12, fontWeight: 700, color: i === 0 ? "#fff" : i === 5 ? (dark ? "#4ade80" : "#16a34a") : t.text }}>
                  {label}
                </div>
                {i < 5 && <span style={{ color: t.muted, fontSize: 16 }}>→</span>}
              </div>
            ))}
          </div>
          <p style={{ ...S.muted, fontSize: 12, margin: "12px 0 0", lineHeight: 1.6 }}>
            Weak topics (Danger Zone) get a tightened loop: 1→2→2→3 days. Strong topics are pushed further out, keeping your brain working at the edge of forgetting — that's where learning happens.
          </p>
        </div>

        {/* Footer */}
        <div style={{ textAlign: "center", ...S.muted, fontSize: 12, paddingBottom: 20 }}>
          Apex · The Road to Grade 9 · Built with science-backed revision methods
        </div>
      </div>
    </div>
  );
}
