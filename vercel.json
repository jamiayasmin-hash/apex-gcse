// ── Colour helpers ────────────────────────────────────────────────────────────
function masteryColor(score, dark) {
  if (score >= 80) return dark ? "#4ade80" : "#16a34a";
  if (score >= 50) return dark ? "#fbbf24" : "#d97706";
  return dark ? "#f87171" : "#dc2626";
}
function masteryLabel(score) {
  if (score >= 80) return "Mastered";
  if (score >= 50) return "Reviewing";
  return "Needs Work";
}

