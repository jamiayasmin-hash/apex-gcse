    const newStreak = correct ? existing.streak + 1 : 0;
    const newCorrect = existing.correct + (correct ? 1 : 0);
    const newTotal = existing.total + 1;
    const newMastery = masteryScore(newCorrect, newTotal, newStreak, newStage);
    const updated = { ...existing, stage: newStage, streak: newStreak, correct: newCorrect, total: newTotal, mastery: newMastery, nextReview: nextReviewDate(newStage, cal.danger), lastResult: cal.label };
