// ── Supabase auth + data helpers ─────────────────────────────────────────────
let _session = null;

async function sbAuth(action, email, password) {
  const res = await fetch(`${SUPABASE_URL}/auth/v1/${action}`, {
    method: "POST",
    headers: { apikey: SUPABASE_ANON_KEY, "Content-Type": "application/json" },
    body: JSON.stringify({ email, password }),
  });
  const data = await res.json();
  if (data.access_token) { _session = data; localStorage.setItem("apex_session", JSON.stringify(data)); }
  return data;
}

async function sbSignOut() {
  if (_session?.access_token) {
    await fetch(`${SUPABASE_URL}/auth/v1/logout`, {
      method: "POST",
      headers: { apikey: SUPABASE_ANON_KEY, Authorization: `Bearer ${_session.access_token}` },
    });
  }
  _session = null;
  localStorage.removeItem("apex_session");
}

function sbGetSession() {
  if (_session) return _session;
  const saved = localStorage.getItem("apex_session");
  if (saved) { _session = JSON.parse(saved); return _session; }
  return null;
}

async function sbFetch(path, opts = {}) {
  const session = sbGetSession();
  const token = session?.access_token || SUPABASE_ANON_KEY;
  const res = await fetch(`${SUPABASE_URL}/rest/v1${path}`, {
    headers: {
      apikey: SUPABASE_ANON_KEY,
      Authorization: `Bearer ${token}`,
      "Content-Type": "application/json",
      Prefer: "return=representation",
      ...opts.headers,
    },
    ...opts,
  });
  if (!res.ok) return null;
  const text = await res.text();
  return text ? JSON.parse(text) : null;
}

async function sbSaveUserData(userId, data) {
  return sbFetch(`/apex_user_data?user_id=eq.${userId}`, {
    method: "POST",
    headers: { Prefer: "resolution=merge-duplicates" },
    body: JSON.stringify({ user_id: userId, data: JSON.stringify(data), updated_at: new Date().toISOString() }),
  });
}

async function sbLoadUserData(userId) {
  const rows = await sbFetch(`/apex_user_data?user_id=eq.${userId}&select=data`);
  if (rows && rows[0]) { try { return JSON.parse(rows[0].data); } catch { return null; } }
  return null;
}

// ── 2357 helpers ─────────────────────────────────────────────────────────────
const STAGES = [2, 3, 5, 7];
function nextReviewDate(stage, weak = false) {
  const days = weak
    ? [1, 2, 2, 3][Math.min(stage, 3)]
    : STAGES[Math.min(stage, 3)];
  const d = new Date();
  d.setDate(d.getDate() + days);
  return d.toISOString().split("T")[0];
}
function masteryScore(correct, total, streak, stage) {
  if (total === 0) return 0;
  const acc = correct / total;
  const stageBonus = stage * 8;
  const streakBonus = Math.min(streak * 5, 20);
  return Math.min(Math.round(acc * 60 + stageBonus + streakBonus), 100);
}
function calibrateResult(confident, correct) {
  if (confident && correct) return { label: "Mastered", advance: true, reset: false, danger: false };
  if (!confident && correct) return { label: "Lucky", advance: false, reset: false, danger: false };
  if (confident && !correct) return { label: "Danger Zone", advance: false, reset: true, danger: true };
  return { label: "Learning Gap", advance: false, reset: true, danger: false };
}

